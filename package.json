{
  "name": "board-game-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx watch server/index.ts",
    "host": "npm run build && npm start",
    "tunnel:cloudflare": "cloudflared tunnel --url http://localhost:3001",
    "host:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-local-tunnel.ps1",
    "host:tunnel:docker": "powershell -ExecutionPolicy Bypass -File scripts/start-local-tunnel.ps1 -Docker",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "tsx server/index.ts",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "create:game": "tsx scripts/create-game-module.ts",
    "qa:catalog": "tsx scripts/qa-game-catalog.ts",
    "qa:games": "tsx scripts/qa-all-games.ts",
    "qa:privacy": "tsx scripts/qa-privacy.ts",
    "qa:timeouts": "tsx scripts/qa-timeouts.ts",
    "qa:new-games": "tsx scripts/qa-three-games.ts",
    "qa:new-games:socket": "tsx scripts/qa-three-games-socket.ts",
    "qa:max": "tsx scripts/qa-all-games.ts --max-runs",
    "qa:all": "npm run build && npm run qa:catalog && npm run qa:new-games && npm run qa:new-games:socket && npm run qa:privacy && npm run qa:timeouts && npm run qa:games"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@radix-ui/themes": "^3.3.0",
    "@types/matter-js": "^0.20.2",
    "@vitejs/plugin-react": "^5.1.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "matter-js": "^0.20.0",
    "motion": "^12.42.2",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.185.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
