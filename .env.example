PORT=3001

# Empty rooms are deleted after this grace period. Default: 30 minutes.
EMPTY_ROOM_GRACE_MS=1800000

# Optional. If empty, stats are stored in ./data/stats.json.
# Use a Postgres connection string from Supabase, Render Postgres, Railway, Fly, or another provider.
DATABASE_URL=
DATABASE_SSL=true
STATS_FILE=./data/stats.json

# Web dev and Android builds can point at a remote Socket.IO/REST server.
VITE_SOCKET_URL=http://127.0.0.1:3001
VITE_API_URL=http://127.0.0.1:3001
